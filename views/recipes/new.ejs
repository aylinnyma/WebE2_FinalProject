<!-- header -->
<%- include('../partials/header') %>

<h1>Add New Recipe</h1>

<% if (typeof error !== 'undefined' && error) { %>
  <p class="error"><%= error %></p>
<% } %>

<form action="/recipes" method="POST" enctype="multipart/form-data"> <!-- enctype req on any form that uploads files (otherwise, file never reaches server and will remain undefined)-->
  <label for="title">Title</label>
  <input type="text" id="title" name="title" required>

  <label for="description">Description / Instructions</label>
  <textarea id="description" name="description" rows="10" required></textarea>

  <label for="category">Category</label>
  <select id="category" name="category" required>
    <!-- this section matches enum on recipe's model -->
    <option value="">Select a category</option>
    <option value="Breakfast">Breakfast</option>
    <option value="Lunch">Lunch</option>
    <option value="Dinner">Dinner</option>
    <option value="Dessert">Dessert</option>
    <option value="Snack">Snack</option>
    <option value="Drink">Drink</option>
  </select>

  <label for="tags">Tags (comma separated)</label>
  <input type="text" id="tags" name="tags" placeholder="e.g. vegan, quick, italian">

  <label for="image">Recipe Image</label>
  <input type="file" id="image" name="image" accept="image/*"> <!-- must match 'image' -->

  <button type="submit">Create Recipe</button>
</form>

<!-- footer -->
<%- include('../partials/footer') %>