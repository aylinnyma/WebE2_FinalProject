<!-- header -->
<%- include('../partials/header') %>

<h1>Edit Recipe</h1>

<form action="/recipes/<%= recipe.slug %>?_method=PUT" method="POST" enctype="multipart/form-data">
  <label for="title">Title</label>
  <input type="text" id="title" name="title" value="<%= recipe.title %>" required> <!-- value= prefills the input with existing value so user does not have to retype everything -->

  <label for="description">Description / Instructions</label>
  <textarea id="description" name="description" rows="10" required><%= recipe.description %></textarea>

  <label for="category">Category</label>
  <select id="category" name="category" required>
    <option value="">Select a category</option>
    <option value="Breakfast" <%= recipe.category === 'Breakfast' ? 'selected' : '' %>>Breakfast</option>
    <option value="Lunch" <%= recipe.category === 'Lunch' ? 'selected' : '' %>>Lunch</option>
    <option value="Dinner" <%= recipe.category === 'Dinner' ? 'selected' : '' %>>Dinner</option>
    <option value="Dessert" <%= recipe.category === 'Dessert' ? 'selected' : '' %>>Dessert</option>
    <option value="Snack" <%= recipe.category === 'Snack' ? 'selected' : '' %>>Snack</option>
    <option value="Drink" <%= recipe.category === 'Drink' ? 'selected' : '' %>>Drink</option>
  </select>

  <label for="tags">Tags (comma separated)</label>
  <input type="text" id="tags" name="tags" value="<%= recipe.tags.join(', ') %>">

  <label for="image">Replace Image (optional)</label>
  <input type="file" id="image" name="image" accept="image/*">
  <p>Current image: <%= recipe.image %></p>

  <button type="submit">Update Recipe</button>
</form>

<!-- footer -->
<%- include('../partials/footer') %>